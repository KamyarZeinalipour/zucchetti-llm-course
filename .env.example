# ============================================================
# LLM Course — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Google AI Studio (Free, Recommended for Labs) ---
# Get your key at: https://aistudio.google.com/apikey
# Free tier: 15 RPM, 1M TPM — more than enough for labs
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# --- DeepSeek API (Cloud Mode) ---
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M input tokens, ~$0.28/M output tokens
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- DeepSeek Model Selection ---
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# --- Ollama (Local Mode) ---
# No API key needed — just install Ollama and pull models
# Default URL (change if running on a remote machine):
OLLAMA_BASE_URL=http://localhost:11434

# --- Ollama Model Selection ---
OLLAMA_CHAT_MODEL=deepseek-r1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=llava:7b

# --- Mode Override ---
# Set to "local" or "cloud" to force a specific mode
# Leave empty for auto-detection (local preferred if available)
LLM_MODE=
